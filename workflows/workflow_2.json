{
  "steps": [
    {
      "name": "place_name",
      "type": "input",
      "prompt": "Place name: "
    },
    {
      "name": "geocode",
      "type": "api",
      "method": "get",
      "url": "https://nominatim.openstreetmap.org/search",
      "headers": {
        "User-Agent": "legibility-demo/0.1"
      },
      "params": {
        "q": "{place_name}, UK",
        "format": "json",
        "limit": "10"
      }
    },
    {
      "name": "date",
      "type": "input",
      "prompt": "Date (yyyy-mm-dd): "
    },
    {
      "name": "get_sunset",
      "type": "api",
      "method": "get",
      "url": "https://api.sunrise-sunset.org/json",
      "params": {
        "lat": "{geocode[0][lat]}",
        "lng": "{geocode[0][lon]}",
        "date": "{date}",
        "formatted": "0"
      }
    },
    {
      "name": "get_weather",
      "type": "api",
      "method": "get",
      "url": "https://api.open-meteo.com/v1/forecast",
      "params": {
        "latitude": "{geocode[0][lat]}",
        "longitude": "{geocode[0][lon]}",
        "start_date": "{date}",
        "end_date": "{date}",
        "daily": "temperature_2m_max,temperature_2m_min,precipitation_sum,weather_code",
        "timezone": "auto"
      }
    },
    {
      "name": "print_output",
      "type": "output",
      "template": "Briefing for {geocode[0][display_name]} on {date}\n  Sunrise : {get_sunset[results][sunrise]}\n  Sunset  : {get_sunset[results][sunset]}\n  Max temp: {get_weather[daily][temperature_2m_max][0]} C\n  Min temp: {get_weather[daily][temperature_2m_min][0]} C\n  Precip  : {get_weather[daily][precipitation_sum][0]} mm"
    }
  ]
}
