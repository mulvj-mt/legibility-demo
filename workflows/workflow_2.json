{
  "description": "Generate a sunrise/sunset and weather briefing for a named UK location and date. Geocodes the location automatically; handles disambiguation if multiple matches are found.",
  "inputs": {
    "place_name": "Name of the UK location (e.g. 'Birkenhead', 'Richmond', 'Keswick')",
    "date": "Date for the briefing in YYYY-MM-DD format (e.g. 2026-06-21)"
  },
  "steps": [
    {
      "name": "place_name",
      "type": "input",
      "prompt": "Place name: "
    },
    {
      "name": "geocode",
      "type": "api",
      "method": "get",
      "url": "https://nominatim.openstreetmap.org/search",
      "headers": {
        "User-Agent": "legibility-demo/0.1"
      },
      "params": {
        "q": "{place_name}, UK",
        "format": "json",
        "limit": "10"
      },
      "transitions": [
        {"target": "date", "cond": "single_result", "on": "store_first_as_location"},
        {"target": "disambiguate_location"}
      ]
    },
    {
      "name": "disambiguate_location",
      "type": "disambiguate",
      "source": "geocode",
      "label_template": "{display_name}",
      "prompt": "Multiple locations found — please choose one:"
    },
    {
      "name": "date",
      "type": "input",
      "prompt": "Date (yyyy-mm-dd): "
    },
    {
      "name": "get_sunset",
      "type": "api",
      "method": "get",
      "url": "https://api.sunrise-sunset.org/json",
      "params": {
        "lat": "{location[lat]}",
        "lng": "{location[lon]}",
        "date": "{date}",
        "formatted": "0"
      }
    },
    {
      "name": "get_weather",
      "type": "api",
      "method": "get",
      "url": "https://api.open-meteo.com/v1/forecast",
      "params": {
        "latitude": "{location[lat]}",
        "longitude": "{location[lon]}",
        "start_date": "{date}",
        "end_date": "{date}",
        "daily": "temperature_2m_max,temperature_2m_min,precipitation_sum,weather_code",
        "timezone": "auto"
      }
    },
    {
      "name": "print_output",
      "type": "output",
      "template": "Briefing for {location[display_name]} on {date}\n  Sunrise : {get_sunset[results][sunrise]}\n  Sunset  : {get_sunset[results][sunset]}\n  Max temp: {get_weather[daily][temperature_2m_max][0]} C\n  Min temp: {get_weather[daily][temperature_2m_min][0]} C\n  Precip  : {get_weather[daily][precipitation_sum][0]} mm"
    },
    {
      "name": "save_report",
      "type": "api",
      "method": "POST",
      "url": "http://127.0.0.1:8001/report",
      "body": {
        "location":      "{location[display_name]}",
        "latitude":      "{location[lat]}",
        "longitude":     "{location[lon]}",
        "report_date":   "{date}",
        "sunrise":       "{get_sunset[results][sunrise]}",
        "sunset":        "{get_sunset[results][sunset]}",
        "precipitation": "{get_weather[daily][precipitation_sum][0]}",
        "max_temp":      "{get_weather[daily][temperature_2m_max][0]}",
        "min_temp":      "{get_weather[daily][temperature_2m_min][0]}"
      }
    }
  ]
}
